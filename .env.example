# Gmail scan settings
GMAIL_PROCESSED_LABEL=mortgage-bot-processed
GMAIL_PRESERVE_UNREAD=true
GMAIL_MAX_MESSAGES_PER_INBOX=25
GMAIL_MAX_TOTAL_PER_INBOX_PER_SCAN=50
