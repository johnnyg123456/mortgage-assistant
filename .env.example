GMAIL_SCAN_TIMEZONE=America/New_York
APPROVAL_PDF_ONLY=true
# Set true while Christy is OOO and mail forwards to John
GMAIL_SKIP_CHRISTY=false
# Retries for transient OAuth/network errors on Render (default 4)
GMAIL_AUTH_RETRIES=4

# Digest schedule
DIGEST_HOURS=8,12,16

DRY_RUN=false
